<%- include("../../partials/header", { title: "Usuarios | VecinosApp" }) %>
<div class="page-head">
  <h1>Usuarios</h1>
  <a class="button" href="/admin/users/new">Nuevo usuario</a>
</div>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Correo</th>
      <th>Perfil</th>
      <th>Edificios</th>
      <th>Estado</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% if (!users.length) { %>
      <tr><td colspan="6">No hay usuarios registrados.</td></tr>
    <% } %>
    <% users.forEach((user) => { %>
      <tr>
        <td><%= user.full_name %></td>
        <td><%= user.email %></td>
        <td><span class="badge"><%= user.role_name || "Sin perfil" %></span></td>
        <td><%= user.building_count %></td>
        <td><span class="badge <%= user.is_active ? "ok" : "muted" %>"><%= user.is_active ? "Activo" : "Inactivo" %></span></td>
        <td class="actions">
          <a href="/admin/users/<%= user.id %>/edit">Editar</a>
          <% if (user.is_active && currentUser.id !== user.id) { %>
            <form method="post" action="/admin/users/<%= user.id %>/deactivate" class="confirmable" data-confirm="¿Desactivar este usuario?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit">Desactivar</button>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../../partials/footer") %>
