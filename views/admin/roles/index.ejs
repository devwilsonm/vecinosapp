<%- include("../../partials/header", { title: "Perfiles | VecinosApp" }) %>
<div class="page-head">
  <h1>Perfiles</h1>
  <a class="button" href="/admin/roles/new">Nuevo perfil</a>
</div>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Clave</th>
      <th>Permisos</th>
      <th>Tipo</th>
      <th>Estado</th>
      <th>Acciones</th>
    </tr>
  </thead>
  <tbody>
    <% roles.forEach((role) => { %>
      <tr>
        <td><%= role.name %></td>
        <td><%= role.key %></td>
        <td><%= role.permission_count %></td>
        <td><span class="badge <%= role.is_system ? "ok" : "muted" %>"><%= role.is_system ? "Sistema" : "Personalizado" %></span></td>
        <td><span class="badge <%= role.is_active ? "ok" : "muted" %>"><%= role.is_active ? "Activo" : "Inactivo" %></span></td>
        <td class="actions"><a href="/admin/roles/<%= role.id %>/edit">Editar</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include("../../partials/footer") %>
