<%- include("../partials/header", { title: "Registrar pago | VecinosApp" }) %>
<section class="page-head"><h1>Registrar pago</h1></section>
<%- include("../partials/errors", { errors }) %>
<div class="detail">
  <p><strong>Ocupante:</strong> <%= allocation.full_name %></p>
  <p><strong>Recibo:</strong> <%= allocation.receipt_number %> · <%= allocation.period %></p>
  <p><strong>Saldo pendiente:</strong> S/ <%= money(allocation.balance_cents) %></p>
</div>
<form method="post" class="form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Monto pagado <input type="number" step="0.01" min="0.01" max="<%= money(allocation.balance_cents) %>" name="amount" required></label>
  <label>Fecha de pago <input type="date" name="payment_date" required></label>
  <label>Método de pago
    <select name="payment_method" required>
      <option value="">Seleccionar</option>
      <option>efectivo</option>
      <option>transferencia</option>
      <option>yape/plin</option>
      <option>otro</option>
    </select>
  </label>
  <label>Observación <textarea name="note"></textarea></label>
  <div class="form-actions"><button class="button" type="submit">Registrar pago</button><a href="/payments">Cancelar</a></div>
</form>
<%- include("../partials/footer") %>
