<%- include("../partials/header", { title: "Ocupantes | VecinosApp" }) %>
<section class="page-head"><h1>Ocupantes</h1><a class="button" href="/occupants/new">Nuevo ocupante</a></section>

<% const buildingNames = Object.keys(groupedOccupants); %>
<% buildingNames.forEach((buildingName) => { const building = groupedOccupants[buildingName]; %>
  <section class="occupant-group">
    <div class="section-head">
      <h2><%= buildingName %></h2>
      <span class="badge muted"><%= building.total %> ocupante<%= building.total === 1 ? "" : "s" %></span>
    </div>
    <div class="accordion-list">
      <% building.floors.forEach((floor, index) => { %>
        <details class="floor-accordion" <%= index === 0 ? "open" : "" %>>
          <summary>
            <span class="floor-title">Piso <%= floor.floor %></span>
            <span class="floor-meta"><%= floor.occupants.length %> ocupante<%= floor.occupants.length === 1 ? "" : "s" %></span>
            <span class="floor-balance"><%= floor.active_count %> activo<%= floor.active_count === 1 ? "" : "s" %></span>
          </summary>
          <table class="compact-table">
            <thead><tr><th>Unidad</th><th>Nombre</th><th>Documento</th><th>Estado</th><th>Acciones</th></tr></thead>
            <tbody>
              <% floor.occupants.forEach((occupant) => { %>
                <tr>
                  <td><%= occupant.unit %></td>
                  <td><%= occupant.full_name %></td>
                  <td><%= occupant.document %></td>
                  <td><span class="badge <%= occupant.is_active ? "ok" : "muted" %>"><%= occupant.is_active ? "Activo" : "Inactivo" %></span></td>
                  <td class="actions">
                    <a href="/occupants/<%= occupant.id %>">Ver</a>
                    <a href="/occupants/<%= occupant.id %>/edit">Editar</a>
                    <form method="post" action="/occupants/<%= occupant.id %>/deactivate"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit">Desactivar</button></form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </details>
        <% }) %>
    </div>
  </section>
<% }) %>

<% if (!buildingNames.length) { %>
  <div class="detail">Sin ocupantes registrados.</div>
<% } %>

<%- include("../partials/footer") %>
